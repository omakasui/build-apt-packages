#!/bin/bash
# Setup script for {{PKG_NAME}}.
# Installs the omakub-based zellij configuration for the current user,
# symlinks the active {{PROJECT}} theme into ~/.config/zellij/themes/current.kdl,
# and sets zellij as the shell in alacritty.toml if alacritty is present.

set -euo pipefail

PACKAGE_DIR="/usr/share/{{PKG_NAME}}"
CONFIG_FILE="${HOME}/.config/zellij/config.kdl"
THEMES_DIR="${HOME}/.config/zellij/themes"
PROJECT_THEME_FILE="${HOME}/.config/{{PROJECT}}/current/theme/zellij.kdl"
ALACRITTY_CONF="${HOME}/.config/alacritty/alacritty.toml"

if [[ ! -d "$PACKAGE_DIR" ]]; then
  echo "Error: {{PKG_NAME}} package not installed"
  exit 1
fi

#  Install zellij config, backing up existing config if present
if [[ -f "$CONFIG_FILE" ]]; then
  if gum confirm "$(echo -e "Zellij config already exists at $CONFIG_FILE.\nThis will create a backup and overwrite it. Continue?")"; then
    BACKUP="${CONFIG_FILE}.backup.$(date +%Y%m%d-%H%M%S)"
    echo "Backing up existing config to $BACKUP"
    cp "$CONFIG_FILE" "$BACKUP"
  else
    echo "Setup cancelled."
    exit 0
  fi
fi

echo "Installing Zellij configuration for {{PROJECT}}..."

mkdir -p "$(dirname "$CONFIG_FILE")"
cp "$PACKAGE_DIR/config/config.kdl" "$CONFIG_FILE"

# Replace {HOME} placeholder in config with actual home directory
# Fix this issue: https://github.com/zellij-org/zellij/issues/4889
sed -i "s|{HOME}|$HOME|g" "$CONFIG_FILE"

# Setup theme symlink
mkdir -p "$THEMES_DIR"

if [[ -f "$PROJECT_THEME_FILE" ]]; then
  ln -snf "$PROJECT_THEME_FILE" "${THEMES_DIR}/current.kdl"
  echo "Theme linked: ${THEMES_DIR}/current.kdl -> $PROJECT_THEME_FILE"
else
  echo "Note: no zellij theme found at $PROJECT_THEME_FILE — run omakub-theme-set to apply one."
fi

# Setup Alacritty shell
if [[ -f "$ALACRITTY_CONF" ]]; then
  if grep -qE '^shell\s*=' "$ALACRITTY_CONF"; then
    sed -i -E 's|^shell\s*=.*|shell = "zellij"|' "$ALACRITTY_CONF"
    echo "Alacritty: shell updated to zellij."
  elif grep -q '^\[terminal\]' "$ALACRITTY_CONF"; then
    sed -i '/^\[terminal\]/a shell = "zellij"' "$ALACRITTY_CONF"
    echo "Alacritty: shell = \"zellij\" added under [terminal]."
  else
    printf '\n[terminal]\nshell = "zellij"\n' >> "$ALACRITTY_CONF"
    echo "Alacritty: [terminal] section with shell = \"zellij\" added."
  fi
fi

echo "{{PKG_NAME}} setup complete!"
