#!/bin/sh
# postinst for alacritty

set -e

case "$1" in
    configure)
        # Register alacritty as an x-terminal-emulator alternative.
        update-alternatives --install /usr/bin/x-terminal-emulator \
            x-terminal-emulator /usr/bin/alacritty 50 \
            2>/dev/null || true
        ;;
esac

exit 0
